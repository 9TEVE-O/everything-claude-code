# YouTube Data API v3
# Get yours: https://console.cloud.google.com -> Enable YouTube Data API v3 -> Credentials -> API Key
YOUTUBE_API_KEY=

# Supabase (https://supabase.com -> New Project -> Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Your deployed app URL (for server-side fetch calls)
NEXT_PUBLIC_APP_URL=https://able-to-answer.vercel.app

# Random secret for Vercel Cron authentication
# Generate with: openssl rand -hex 32
CRON_SECRET=
